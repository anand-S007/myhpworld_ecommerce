# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/myhpworld
# Or MongoDB Atlas (replace <user>, <pass>, <cluster>):
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/myhpworld?retryWrites=true&w=majority

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Use long random strings in production (e.g. `openssl rand -hex 48`)
JWT_SECRET=replace_with_a_long_random_string
JWT_ADMIN_SECRET=replace_with_a_different_long_random_string
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origin allowed to call the API (the Vite dev server by default)
CLIENT_ORIGIN=http://localhost:5173

# ─── SMTP (used for OTP + order / newsletter emails) ─────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM="HP World <you@example.com>"
# SMTP_SECURE=false   # defaults: false on 587, true on 465
